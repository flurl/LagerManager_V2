# Database
POSTGRES_DB=lagermanager
POSTGRES_USER=lagermanager
POSTGRES_PASSWORD=change-me-strong-password

# Django
DATABASE_URL=postgres://lagermanager:change-me-strong-password@db:5432/lagermanager
DJANGO_SECRET_KEY=change-me-long-random-secret-key
DJANGO_DEBUG=False

# Comma-separated list of allowed hosts (no scheme, no port)
DJANGO_ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com

# Comma-separated list of trusted origins (with scheme)
CSRF_TRUSTED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# CORS — origins that may call the API (with scheme, no trailing slash)
CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
